{
  "expo": {
    "name": "unicopa",
    "slug": "unicopa",
    "version": "1.0.0",
    "orientation": "portrait",

    "icon": "./assets/unicopa.png",

    "userInterfaceStyle": "light",

    "newArchEnabled": true,

    "splash": {
      "image": "./assets/unicopa.png",
      "resizeMode": "contain",
      "backgroundColor": "#040b13"
    },

    "ios": {
      "supportsTablet": true
    },

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/unicopa.png",
        "backgroundColor": "#040b13"
      },
      "edgeToEdgeEnabled": true
    },

    "web": {},

    "plugins": [
      "expo-sqlite"
    ]
  }
}